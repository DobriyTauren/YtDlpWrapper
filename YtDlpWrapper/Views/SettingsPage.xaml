<Page x:Class="YtDlpWrapper.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <Grid Padding="32, 0, 32, 32">
            <StackPanel
                Spacing="24"
                MaxWidth="600"
                Width="520"
                HorizontalAlignment="Left">
                
                <!-- CARD: Download folder -->
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefault}"
                    CornerRadius="20"
                    Padding="24">

                    <StackPanel Spacing="12">
                        <TextBlock
                            Text="Папка для сохранения файлов"
                            Foreground="{ThemeResource TextFillColorSecondary}"/>

                        <TextBox
                                Text="{Binding DownloadFolder}"
                                IsReadOnly="True"/>

                        <StackPanel Orientation="Horizontal" >
                            <Button
                                Content="Изменить"
                                Command="{Binding ChooseFolderCommand}"
                                Grid.Column="1"/>

                            <Button 
                                Margin="12,0,0,0"
                                Content="Открыть папку"
                                Command="{Binding OpenFolderCommand}"
                                Grid.Column="1"/>
                        </StackPanel>


                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
