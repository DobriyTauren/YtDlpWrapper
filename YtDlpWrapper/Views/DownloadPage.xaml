<Page
    x:Class="YtDlpWrapper.Views.DownloadPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:viewmodels="using:YtDlpWrapper.ViewModels" xmlns:conv="using:YtDlpWrapper.Utils" xmlns:d="http://schemas.microsoft.com/expression/blend/2008">


    <Page.Resources>
        <conv:BoolToBrushConverter x:Key="BoolToBrushConverter"
                                   TrueBrush="#db9ee4"
                                   FalseBrush="Transparent"/>

        <conv:BoolToBrushConverter x:Key="InverseBoolToBrushConverter"
                                   Invert="True"
                                   TrueBrush="#db9ee4"
                                   FalseBrush="Transparent"/>

        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <conv:BoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" Invert="True"/>

        <Style x:Key="ToggleButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="230"/>
            <Setter Property="CornerRadius" Value="10"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border
                                x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                                <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                            </Border>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">

                                    <!-- Pressed -->
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background"
                                            Value="#9c6bb0"/>
                                        </VisualState.Setters>
                                    </VisualState>

                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>
    
    <ScrollViewer>
        <Grid Padding="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HERO CARD -->
            <Border
            Background="{ThemeResource CardBackgroundFillColorDefault}"
            CornerRadius="20"
            Padding="24"
            Width="520"
            HorizontalAlignment="Left"
            VerticalAlignment="Top">

                <StackPanel Spacing="20">

                    <!-- URL -->
                    <TextBox
                    PlaceholderText="Вставьте ссылку на видео"
                    Text="{Binding Current.Url, Mode=TwoWay}"
                    Height="44"/>

                    <!-- TYPE SWITCH -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">

                        <!-- Видео -->
                        <Button Content="🎬 Видео"
                            Style="{StaticResource ToggleButtonStyle}"
                            Command="{Binding VideoButtonCommand}"
                            Background="{Binding IsVideo, Converter={StaticResource BoolToBrushConverter}}"/>

                        <Button Content="🎵 Аудио"
                            Style="{StaticResource ToggleButtonStyle}"
                            Command="{Binding AudioButtonCommand}"
                            Background="{Binding IsVideo, Converter={StaticResource InverseBoolToBrushConverter}}"/>

                    </StackPanel>

                    <!-- OPTIONS -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <ComboBox
                            Header="Формат"
                            ItemsSource="{Binding Formats}"
                            SelectedItem="{Binding Format, Mode=TwoWay}"
                            Grid.Column="0"/>

                        <ComboBox
                            Header="Качество"
                            ItemsSource="{Binding VideoQualities}"
                            SelectedItem="{Binding VideoQuality, Mode=TwoWay}"
                            Grid.Column="1"
                            Visibility="{Binding IsVideo, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>

                    <!-- DOWNLOAD -->
                    <Button
                        Content="Скачать"
                        FontSize="16"
                        Height="44"
                        HorizontalAlignment="Stretch"
                        Style="{ThemeResource AccentButtonStyle}"
                        Command="{Binding DownloadCommand}"
                        Visibility="{Binding Current.IsDownloading,
                        Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                    <!-- CANCEL -->
                    <Button
                        Content="Отменить"
                        FontSize="16"
                        Height="44"
                        HorizontalAlignment="Stretch"
                        Style="{ThemeResource AccentButtonStyle}"
                        Command="{Binding CancelCommand}"
                        Visibility="{Binding Current.IsDownloading,
                        Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ProgressBar
                            Grid.Column="0"
                            Minimum="0"
                            Maximum="100"
                            Value="{Binding Current.Progress}"
                            MinHeight="12"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"/>

                        <TextBlock
                            Grid.Column="1"
                            Text="{Binding Current.Status}"
                            Opacity="0.7"
                            FontSize="12"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

            </Border>
        </Grid>
    </ScrollViewer>

</Page>
