<Page
    x:Class="YtDlpWrapper.Views.DownloadPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:YtDlpWrapper.ViewModels"
    xmlns:conv="using:YtDlpWrapper.Utils"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008">

    <Page.Resources>
        <conv:EnumDescriptionConverter x:Key="EnumDescriptionConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:BoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" Invert="True"/>
        <conv:BoolNegationConverter x:Key="BoolNegationConverter"/>
    </Page.Resources>

    <ScrollViewer>
        <Grid Padding="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border
                Background="{ThemeResource CardBackgroundFillColorDefault}"
                CornerRadius="20"
                Padding="24"
                Width="auto"
                MaxWidth="550"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top">

                <StackPanel Spacing="20">
                    <TextBox
                        x:Uid="DownloadUrlTextBox"
                        Text="{Binding CurrentDownload.Url, Mode=TwoWay}"
                        Padding="12,10,0,10"
                        VerticalContentAlignment="Center"
                        Height="44"/>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Button
                                x:Uid="VideoSelectedButton"
                                Height="40"
                                CornerRadius="10"
                                HorizontalAlignment="Stretch"
                                Style="{ThemeResource AccentButtonStyle}"
                                Command="{Binding VideoButtonCommand}"
                                IsEnabled="{Binding IsUpdatingYtDlp, Converter={StaticResource BoolNegationConverter}}"
                                Visibility="{Binding IsVideo, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <Button
                                x:Uid="VideoUnselectedButton"
                                Height="40"
                                CornerRadius="10"
                                HorizontalAlignment="Stretch"
                                Background="Transparent"
                                Command="{Binding VideoButtonCommand}"
                                IsEnabled="{Binding IsUpdatingYtDlp, Converter={StaticResource BoolNegationConverter}}"
                                Visibility="{Binding IsVideo, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        </Grid>

                        <Grid Grid.Column="1">
                            <Button
                                x:Uid="AudioSelectedButton"
                                Height="40"
                                CornerRadius="10"
                                HorizontalAlignment="Stretch"
                                Style="{ThemeResource AccentButtonStyle}"
                                Command="{Binding AudioButtonCommand}"
                                IsEnabled="{Binding IsUpdatingYtDlp, Converter={StaticResource BoolNegationConverter}}"
                                Visibility="{Binding IsVideo, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                            <Button
                                x:Uid="AudioUnselectedButton"
                                Height="40"
                                CornerRadius="10"
                                HorizontalAlignment="Stretch"
                                Background="Transparent"
                                Command="{Binding AudioButtonCommand}"
                                IsEnabled="{Binding IsUpdatingYtDlp, Converter={StaticResource BoolNegationConverter}}"
                                Visibility="{Binding IsVideo, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </Grid>
                    </Grid>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <ComboBox
                            x:Uid="FormatComboBox"
                            ItemsSource="{Binding Formats}"
                            SelectedItem="{Binding Format, Mode=TwoWay}"
                            Grid.Column="0"/>

                        <ComboBox
                            x:Uid="QualityComboBox"
                            ItemsSource="{Binding VideoQualities}"
                            SelectedItem="{Binding VideoQuality, Mode=TwoWay}"
                            Visibility="{Binding IsVideo, Converter={StaticResource BoolToVisibilityConverter}}"
                            Grid.Column="1">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <Button
                        x:Uid="DownloadButton"
                        FontSize="16"
                        Height="44"
                        HorizontalAlignment="Stretch"
                        Style="{ThemeResource AccentButtonStyle}"
                        Command="{Binding DownloadCommand}"
                        IsEnabled="{Binding IsUpdatingYtDlp, Converter={StaticResource BoolNegationConverter}}"
                        Visibility="{Binding CurrentDownload.IsDownloading, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                    <Button
                        x:Uid="CancelButton"
                        FontSize="16"
                        Height="44"
                        HorizontalAlignment="Stretch"
                        Style="{ThemeResource AccentButtonStyle}"
                        Command="{Binding CancelCommand}"
                        Visibility="{Binding CurrentDownload.IsDownloading, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Grid
                        ColumnSpacing="10"
                        Visibility="{Binding IsUpdatingYtDlp, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ProgressRing
                            Grid.Column="0"
                            Width="18"
                            Height="18"
                            IsActive="True"
                            VerticalAlignment="Center"/>

                        <TextBlock
                            x:Uid="YtDlpUpdateNoticeText"
                            Grid.Column="1"
                            Opacity="0.8"
                            TextWrapping="Wrap"
                            VerticalAlignment="Center"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ProgressBar
                            Grid.Column="0"
                            Minimum="0"
                            Maximum="100"
                            Value="{Binding CurrentDownload.Progress, Mode=TwoWay}"
                            MinHeight="12"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"/>

                        <TextBlock
                            Grid.Column="1"
                            Text="{Binding CurrentDownload.Status}"
                            Opacity="0.7"
                            FontSize="12"
                            Margin="8,0,0,0"
                            TextAlignment="Right"
                            TextTrimming="CharacterEllipsis"
                            VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
